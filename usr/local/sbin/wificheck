#!/usr/bin/env python3
"""
WiFi reconnection check script for tsOS-base.
Scans for the configured WiFi station (client) SSID when the hotspot is active,
and attempts to reconnect to the station if it is detected in range.
"""

import os
import sys
import subprocess
import configparser
import logging

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s",
    handlers=[logging.StreamHandler(sys.stdout)]
)

STATION_FILE = "/etc/NetworkManager/system-connections/station.nmconnection"

def is_station_active() -> bool:
    """Check if the station connection is currently active."""
    try:
        result = subprocess.run(
            ["nmcli", "-t", "-f", "NAME,STATE", "connection", "show", "--active"],
            capture_output=True,
            text=True,
            check=True
        )
        for line in result.stdout.strip().split("\n"):
            if not line:
                continue
            parts = line.split(":")
            if len(parts) >= 2 and parts[0] == "station" and "activated" in parts[1]:
                return True
    except Exception as e:
        logging.error(f"Error checking active connections: {e}")
    return False

def is_autoconnect_enabled() -> bool:
    """Read and check if autoconnect is enabled in the station connection file."""
    if not os.path.exists(STATION_FILE):
        return False
    try:
        config = configparser.ConfigParser()
        config.read(STATION_FILE)
        if "connection" in config:
            # If the autoconnect key is absent, NetworkManager defaults to true
            autoconnect_val = config["connection"].get("autoconnect", "true").lower()
            return autoconnect_val in ("true", "yes", "1")
    except Exception as e:
        logging.error(f"Error reading autoconnect from {STATION_FILE}: {e}")
    # Default to True to match NetworkManager's behavior if parsing fails
    return True

def get_configured_ssid() -> str:
    """Read the configured SSID from the station nmconnection file."""
    if not os.path.exists(STATION_FILE):
        logging.warning(f"Station connection file {STATION_FILE} not found.")
        return ""
    try:
        config = configparser.ConfigParser()
        config.read(STATION_FILE)
        if "wifi" in config and "ssid" in config["wifi"]:
            return config["wifi"]["ssid"]
    except Exception as e:
        logging.error(f"Error reading SSID from {STATION_FILE}: {e}")
    return ""

def is_ssid_in_range(ssid: str) -> bool:
    """Scan and check if the given SSID is in range."""
    if not ssid:
        return False
    try:
        # Find WiFi interface name (typically wlan0)
        result = subprocess.run(
            ["nmcli", "-t", "-f", "DEVICE,TYPE", "device", "status"],
            capture_output=True,
            text=True,
            check=True
        )
        iface = "wlan0"
        for line in result.stdout.strip().split("\n"):
            parts = line.split(":")
            if len(parts) >= 2 and parts[1] == "wifi":
                iface = parts[0]
                break
        
        logging.info(f"Triggering wifi rescan on interface '{iface}'...")
        # Ignore errors if rescan is rate-limited
        subprocess.run(["nmcli", "device", "wifi", "rescan", "ifname", iface], capture_output=True)
        
        # List the available SSIDs
        list_result = subprocess.run(
            ["nmcli", "-t", "-f", "SSID", "device", "wifi", "list"],
            capture_output=True,
            text=True,
            check=True
        )
        
        visible_ssids = [line.strip() for line in list_result.stdout.strip().split("\n") if line.strip()]
        logging.info(f"Visible SSIDs: {visible_ssids}")
        
        # exact match or escaped colons matching
        escaped_ssid = ssid.replace(":", "\\:")
        if ssid in visible_ssids or escaped_ssid in visible_ssids:
            return True
            
    except Exception as e:
        logging.error(f"Error scanning wifi networks: {e}")
    return False

def connect_to_station() -> bool:
    """Try to connect to the station connection."""
    logging.info("Station SSID in range! Attempting to reconnect to 'station'...")
    try:
        result = subprocess.run(
            ["nmcli", "connection", "up", "station"],
            capture_output=True,
            text=True,
            timeout=45
        )
        if result.returncode == 0:
            logging.info("Successfully reconnected to 'station'.")
            return True
        else:
            logging.warning(f"Failed to connect to 'station': {result.stderr.strip() or result.stdout.strip()}")
    except subprocess.TimeoutExpired:
        logging.error("Connection attempt to 'station' timed out.")
    except Exception as e:
        logging.error(f"Error bringing up station connection: {e}")
    return False

def main():
    if is_station_active():
        logging.info("Already connected to 'station'. No action needed.")
        return

    # Check if autoconnect is enabled for the station connection
    if not is_autoconnect_enabled():
        logging.info("Autoconnect is disabled for the 'station' connection. Skipping check.")
        return

    ssid = get_configured_ssid()
    if not ssid:
        logging.info("No station SSID is configured in station.nmconnection. Exiting.")
        return

    logging.info(f"Checking if configured station SSID '{ssid}' is in range...")
    if is_ssid_in_range(ssid):
        connect_to_station()
    else:
        logging.info(f"Station SSID '{ssid}' is not in range.")

if __name__ == "__main__":
    main()
